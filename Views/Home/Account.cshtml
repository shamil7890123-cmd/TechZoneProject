@model TechZoneProject.Models.User

@{ ViewBag.Title = "Личный кабинет"; }

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Личный кабинет — TechZone</title>
    <link rel="stylesheet" href="~/Content/style.css"> 
</head>
<body>
    <main class="container">
        <h1 class="catalog-main-title">Личный кабинет</h1>

        <div class="account-two-columns">
            <div class="account-sidebar">
                <section class="account-box">
                    <h2 class="box-title">Профиль</h2>
                    <div class="form-group">
                        <label>Логин</label>
                        <input type="text" value="@Model.Login" readonly>
                    </div>
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" value="@Model.Email" readonly>
                    </div>
                    <div class="form-group">
                        <label>Ваша роль</label>
                        <input type="text" value="@(Model.Role == "Admin" ? "Администратор" : "Клиент")" readonly>
                    </div>
                    <p style="font-size: 12px; color: #6c757d;">* Редактирование профиля будет доступно в следующей версии</p>
                </section>
            </div>

            <div class="account-main-content">
                <section class="orders-box">
                    <h2 class="box-title">Статус аккаунта</h2>
                    <p>Добро пожаловать, <strong>@Model.Login</strong>!</p>
                    <p>Вы успешно авторизованы в системе TechZone.</p>

                    @if (Model.Role == "Admin")
                    {
                        <div style="margin-top: 20px; padding: 15px; background: #e7f1ff; border-radius: 8px;">
                            <p><strong>Панель управления:</strong></p>
                            <a href="@Url.Action("users")" class="order-link">Управление клиентами</a> |
                            <a href="@Url.Action("products")" class="order-link">Управление товарами</a>
                        </div>
                    }
                </section>
            </div>
        </div>
    </main>
</body>
</html>